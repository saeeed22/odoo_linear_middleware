# Server
PORT=3000
NODE_ENV=development

# Database
#
# Two supported setups:
#
# 1. Compose Postgres — default `docker-compose.yml`:
#      DATABASE_URL is set directly in docker-compose.yml and overrides this
#      value. You can leave the example string as-is.
#
# 2. Host Postgres — `docker-compose.local.yml`:
#      Set DATABASE_URL to point at your host DB reachable from inside Docker.
#      On Windows/macOS Docker Desktop, use host.docker.internal:
#        DATABASE_URL=postgresql://<user>:<pass>@host.docker.internal:5432/<db>?schema=linear
#      On Linux, use the host's bridge gateway IP (usually 172.17.0.1) or add
#      `extra_hosts: ["host.docker.internal:host-gateway"]` to the services.
#
# Always include `?schema=linear` so Prisma writes tables under the linear schema.
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/middleware_db?schema=linear

# Redis (BullMQ). Inside Compose this resolves to the `redis` service.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Linear
LINEAR_API_KEY=lin_api_XXXXXXXXXXXXXXXXXXXX
LINEAR_WEBHOOK_SECRET=your_webhook_secret_here
LINEAR_BOT_USER_ID=linear_bot_user_id_here
LINEAR_TEAM_ID=linear_team_id_here

# Odoo
ODOO_BASE_URL=https://your-odoo-instance.com
ODOO_DB=your_database_name
ODOO_USERNAME=admin@example.com
ODOO_PASSWORD=your_password
ODOO_BOT_USER_ID=3

# Polling
ODOO_POLL_INTERVAL_MS=30000

# Important: Status/Stage ID Mappings
# After setting credentials, you must update the following config files with YOUR actual IDs:
# 1. src/config/status-mapping.ts - Linear State Names → Odoo Stage IDs
# 2. src/config/odoo-stage-mapping.ts - Odoo Stage IDs → Linear State IDs
# See SETUP.md for instructions on finding these IDs in your instances
